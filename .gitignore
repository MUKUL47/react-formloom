# ── git layer: track the whole repo (source, tests, demo, config, docs) ──
# The npm publish layer is controlled separately by .npmignore.

node_modules
dist
dist-site
test-results
playwright-report
*.log
.DS_Store

# Vite transpiles a TS config to a temp .mjs beside it and normally deletes
# it — an interrupted build leaves it behind, and npm pack will ship it.
*.timestamp-*.mjs

# Local sandbox that installs formloom from npm to test what consumers get.
_dev

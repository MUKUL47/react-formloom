{
  "name": "formloom",
  "version": "1.0.0",
  "description": "A React drag-and-drop form builder + runtime renderer, plus a standalone, dependency-free schema→Zod validator (formloom/validator) for server-side validation. 24 field types, hooks, reactive side effects, sections/tabs/arrays, custom widgets, file uploads.",
  "type": "module",
  "license": "MIT",
  "author": "Mukul Dutt <mukuldutt1234@gmail.com>",
  "homepage": "https://mukul47.github.io/reactcustomformbuilder/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MUKUL47/reactcustomformbuilder.git"
  },
  "bugs": {
    "url": "https://github.com/MUKUL47/reactcustomformbuilder/issues"
  },
  "keywords": [
    "react",
    "form",
    "form-builder",
    "drag-and-drop",
    "form-renderer",
    "dnd-kit",
    "schema",
    "json-schema",
    "no-code",
    "low-code",
    "dynamic-forms",
    "form-generator",
    "typescript",
    "tailwind",
    "shadcn",
    "zod",
    "validation",
    "schema-to-zod"
  ],
  "sideEffects": true,
  "main": "./dist/formloom.js",
  "module": "./dist/formloom.js",
  "types": "./dist/components/react-custom-form-builder/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/components/react-custom-form-builder/index.d.ts",
      "import": "./dist/formloom.js"
    },
    "./validator": {
      "types": "./dist/validator/schema-to-zod.d.ts",
      "import": "./dist/validator.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tailwind-preset": "./tailwind-preset.cjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "vite build --config vite.lib.config.ts && npm run build:css",
    "build:css": "tailwindcss -c tailwind.lib.config.cjs -i src/styles/formloom.css -o dist/styles.css --minify",
    "preview": "vite preview",
    "prepack": "npm run build:lib",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:validator": "tsx --test src/validator/*.test.ts"
  },
  "dependencies": {
    "zod": "^4"
  },
  "peerDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
